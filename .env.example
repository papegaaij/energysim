# Copy this file to `.env` and fill in your values.

# Home Assistant long-lived access token.
# Create one in HA: Profile -> Security -> Long-lived access tokens -> Create token.
HA_TOKEN=

# Optional: default Home Assistant base URL (you can also just type it when prompted).
# Examples: https://homeassistant.local:8123  or  https://ha.example.com
HA_URL=

# Optional: set to false to skip TLS certificate verification (useful for self-signed
# certificates on a local instance). Defaults to true.
HA_VERIFY_SSL=true
